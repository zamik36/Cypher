{
  "uid": "cypher-logs",
  "title": "Cypher Logs",
  "description": "Centralized logs from Gateway, Signaling, and Relay services via Loki",
  "tags": ["cypher", "logs"],
  "timezone": "browser",
  "refresh": "10s",
  "time": {
    "from": "now-30m",
    "to": "now"
  },
  "templating": {
    "list": [
      {
        "name": "service",
        "type": "custom",
        "current": { "text": "All", "value": "" },
        "options": [
          { "text": "All", "value": "", "selected": true },
          { "text": "gateway", "value": "gateway", "selected": false },
          { "text": "signaling", "value": "signaling", "selected": false },
          { "text": "relay", "value": "relay", "selected": false }
        ],
        "query": "gateway,signaling,relay",
        "includeAll": true,
        "allValue": ""
      },
      {
        "name": "level",
        "type": "custom",
        "current": { "text": "All", "value": "" },
        "options": [
          { "text": "All", "value": "", "selected": true },
          { "text": "ERROR", "value": "ERROR", "selected": false },
          { "text": "WARN", "value": "WARN", "selected": false },
          { "text": "INFO", "value": "INFO", "selected": false },
          { "text": "DEBUG", "value": "DEBUG", "selected": false }
        ],
        "query": "ERROR,WARN,INFO,DEBUG",
        "includeAll": true,
        "allValue": ""
      }
    ]
  },
  "panels": [
    {
      "type": "row",
      "title": "Error Rate",
      "gridPos": { "x": 0, "y": 0, "w": 24, "h": 1 },
      "collapsed": false
    },
    {
      "type": "timeseries",
      "title": "Errors / min by Service",
      "gridPos": { "x": 0, "y": 1, "w": 12, "h": 7 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "sum by (service) (count_over_time({job=\"docker\", service=~\".+\"} | json | level = \"ERROR\" [1m]))",
          "legendFormat": "{{service}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 20,
            "gradientMode": "scheme",
            "showPoints": "auto",
            "pointSize": 5,
            "spanNulls": false
          },
          "unit": "short"
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      }
    },
    {
      "type": "timeseries",
      "title": "Warnings / min by Service",
      "gridPos": { "x": 12, "y": 1, "w": 12, "h": 7 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "sum by (service) (count_over_time({job=\"docker\", service=~\".+\"} | json | level = \"WARN\" [1m]))",
          "legendFormat": "{{service}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 20,
            "gradientMode": "scheme",
            "showPoints": "auto",
            "pointSize": 5,
            "spanNulls": false
          },
          "unit": "short"
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      }
    },
    {
      "type": "row",
      "title": "Log Stream",
      "gridPos": { "x": 0, "y": 8, "w": 24, "h": 1 },
      "collapsed": false
    },
    {
      "type": "logs",
      "title": "All Service Logs",
      "gridPos": { "x": 0, "y": 9, "w": 24, "h": 14 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "{job=\"docker\", service=~\"${service:regex}\"} | json ${level:pipe}",
          "refId": "A"
        }
      ],
      "options": {
        "showTime": true,
        "showLabels": true,
        "showCommonLabels": false,
        "wrapLogMessage": true,
        "prettifyLogMessage": true,
        "enableLogDetails": true,
        "sortOrder": "Descending",
        "dedupStrategy": "none"
      }
    },
    {
      "type": "row",
      "title": "Per-Service Logs",
      "gridPos": { "x": 0, "y": 23, "w": 24, "h": 1 },
      "collapsed": false
    },
    {
      "type": "logs",
      "title": "Gateway Logs",
      "gridPos": { "x": 0, "y": 24, "w": 24, "h": 10 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "{job=\"docker\", service=\"gateway\"} | json",
          "refId": "A"
        }
      ],
      "options": {
        "showTime": true,
        "showLabels": false,
        "wrapLogMessage": true,
        "prettifyLogMessage": true,
        "enableLogDetails": true,
        "sortOrder": "Descending",
        "dedupStrategy": "none"
      }
    },
    {
      "type": "logs",
      "title": "Signaling Logs",
      "gridPos": { "x": 0, "y": 34, "w": 24, "h": 10 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "{job=\"docker\", service=\"signaling\"} | json",
          "refId": "A"
        }
      ],
      "options": {
        "showTime": true,
        "showLabels": false,
        "wrapLogMessage": true,
        "prettifyLogMessage": true,
        "enableLogDetails": true,
        "sortOrder": "Descending",
        "dedupStrategy": "none"
      }
    },
    {
      "type": "logs",
      "title": "Relay Logs",
      "gridPos": { "x": 0, "y": 44, "w": 24, "h": 10 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "{job=\"docker\", service=\"relay\"} | json",
          "refId": "A"
        }
      ],
      "options": {
        "showTime": true,
        "showLabels": false,
        "wrapLogMessage": true,
        "prettifyLogMessage": true,
        "enableLogDetails": true,
        "sortOrder": "Descending",
        "dedupStrategy": "none"
      }
    }
  ],
  "schemaVersion": 39,
  "version": 1
}
